) c++ program for addition of two numbers using dma
#include <iostream>

using namespace std;

int main() {
    int n, sum = 0;
    int* ptr; // Declare an integer pointer

    // Prompt the user to enter the number of elements
    cout << "Enter the number of elements: ";
    cin >> n;

    // Dynamically allocate memory for an array of 'n' integers
    ptr = new int[n];

    // Check if memory allocation was successful
    if (ptr == nullptr) {
        cout << "Error! memory not allocated." << endl;
        return 1; // Exit program with an error code
    }

    // Input elements from the user and calculate the sum
    cout << "Enter elements: " << endl;
    for (int i = 0; i < n; ++i) {
        cout << "Element " << i + 1 << ": ";
        cin >> ptr[i]; // Store the input in the dynamically allocated array
        sum += ptr[i]; // Add the element to the sum
    }

    // Display the sum of the elements
    cout << "Sum = " << sum << endl;

    // Deallocate the dynamically allocated memory
    delete[] ptr;
    ptr = nullptr; // Good practice to set pointer to nullptr after deallocation

    return 0;
} 
#include <iostream>
using namespace std;

// Node structure
struct Node {
    int data;     // Data field
    Node* next;   // Pointer to the next node

    // Constructor to easily create a new node
    Node(int val) : data(val), next(nullptr) {}
};

// Function to print the linked list (traversal)
void printList(Node* head) {
    Node* current = head; // Start from the head
    while (current != nullptr) { // Traverse until the end (NULL)
        cout << current->data << " "; // Print data
        current = current->next;     // Move to the next node
    }
    cout << endl;
}
